from datetime import datetime, timezone
from email.utils import format_datetime
from pathlib import Path
from urllib.parse import urljoin
import html
import re

import requests
from bs4 import BeautifulSoup


SOURCE_URL = "https://www.sdis38.fr/44-actualites.htm"
SITE_URL = "https://www.sdis38.fr/"
OUTPUT_FILE = Path("rss.xml")


def clean_text(text):
    """Supprime les retours à la ligne et les espaces inutiles."""
    return re.sub(r"\s+", " ", text or "").strip()


def xml_escape(text):
    """Évite que certains caractères cassent le fichier XML."""
    return html.escape(text or "", quote=True)


def find_image(container):
    """Recherche l'image de l'actualité."""
    if not container:
        return ""

    image = container.find("img")

    if not image:
        return ""

    image_url = (
        image.get("src")
        or image.get("data-src")
        or image.get("data-original")
        or ""
    )

    return urljoin(SITE_URL, image_url)


def find_date(text):
    """Recherche une date au format jour/mois/année."""
    match = re.search(r"\b(\d{2}/\d{2}/\d{4})\b", text)

    if match:
        return match.group(1)

    return ""


def download_page():
    """Télécharge la page des actualités du SDIS 38."""
    headers = {
        "User-Agent": (
            "Mozilla/5.0 "
            "(compatible; SDIS38-RSS/1.0; +https://github.com/)"
        )
    }

    response = requests.get(
        SOURCE_URL,
        headers=headers,
        timeout=30,
    )

    response.raise_for_status()

    return response.text


def extract_articles(page_html):
    """Récupère les actualités présentes sur la page."""
    soup = BeautifulSoup(page_html, "html.parser")

    articles = []
    urls_already_added = set()

    for link in soup.find_all("a", href=True):
        href = link.get("href", "")

        # On conserve uniquement les liens qui semblent correspondre
        # à une actualité du SDIS 38.
        if "actualite" not in href.lower():
            continue

        article_url = urljoin(SITE_URL, href)
        title = clean_text(link.get_text(" ", strip=True))

        if not title:
            continue

        # Évite les liens trop courts ou les boutons génériques.
        if title.lower() in {
            "lire la suite",
            "en savoir plus",
            "actualités",
            "dernières nouvelles",
        }:
            continue

        if article_url in urls_already_added:
            continue

        container = link.find_parent(
            ["article", "li", "section", "div"]
        )

        if container:
            full_text = clean_text(
                container.get_text(" ", strip=True)
            )
        else:
            full_text = title

        date_text = find_date(full_text)
        image_url = find_image(container)

        description = full_text

        if title in description:
            description = description.replace(title, "", 1)

        if date_text and date_text in description:
            description = description.replace(date_text, "", 1)

        description = clean_text(description)

        if len(description) > 500:
            description = description[:497] + "..."

        articles.append(
            {
                "title": title,
                "url": article_url,
                "date": date_text,
                "description": description,
                "image": image_url,
            }
        )

        urls_already_added.add(article_url)

    return articles[:20]


def create_rss(articles):
    """Crée le contenu complet du fichier RSS."""
    rss_items = []

    for article in articles:
        try:
            publication_date = datetime.strptime(
                article["date"],
                "%d/%m/%Y",
            ).replace(tzinfo=timezone.utc)
        except ValueError:
            publication_date = datetime.now(timezone.utc)

        image_html = ""
        enclosure_xml = ""
        media_xml = ""

        if article["image"]:
            escaped_image = xml_escape(article["image"])

            image_html = (
                f'<p><img src="{escaped_image}" '
                f'alt="{xml_escape(article["title"])}" /></p>'
            )

            enclosure_xml = (
                f'<enclosure url="{escaped_image}" '
                f'type="image/jpeg" />'
            )

            media_xml = (
                f'<media:content url="{escaped_image}" '
                f'medium="image" />'
            )

        description_html = (
            image_html
            + "<p>"
            + xml_escape(article["description"])
            + "</p>"
        )

        rss_item = f"""
    <item>
      <title>{xml_escape(article["title"])}</title>
      <link>{xml_escape(article["url"])}</link>
      <guid isPermaLink="true">{xml_escape(article["url"])}</guid>
      <pubDate>{format_datetime(publication_date)}</pubDate>
      <description><![CDATA[{description_html}]]></description>
      {enclosure_xml}
      {media_xml}
    </item>
"""

        rss_items.append(rss_item)

    build_date = format_datetime(datetime.now(timezone.utc))

    rss_content = f"""<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0"
     xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>Actualités du SDIS 38</title>
    <link>{SOURCE_URL}</link>
    <description>
      Actualités officielles du Service départemental
      d'incendie et de secours de l'Isère
    </description>
    <language>fr-fr</language>
    <lastBuildDate>{build_date}</lastBuildDate>
    <ttl>60</ttl>
{''.join(rss_items)}
  </channel>
</rss>
"""

    return rss_content


def main():
    print("Téléchargement de la page du SDIS 38...")

    page_html = download_page()

    print("Recherche des actualités...")

    articles = extract_articles(page_html)

    if not articles:
        raise RuntimeError(
            "Aucune actualité trouvée. "
            "La structure du site a peut-être changé."
        )

    print(f"{len(articles)} actualités trouvées.")

    rss_content = create_rss(articles)

    OUTPUT_FILE.write_text(
        rss_content,
        encoding="utf-8",
    )

    print("Le fichier rss.xml a été créé avec succès.")


if __name__ == "__main__":
    main()
